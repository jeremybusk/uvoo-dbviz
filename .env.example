SQVIZ_ADDR=:8080
SQVIZ_BIND_ADDR=0.0.0.0
SQVIZ_PUBLIC_HOST=localhost
SQVIZ_AUTH_DEV_MODE=true
SQVIZ_CLICKHOUSE_URL=http://clickhouse:8123
SQVIZ_CLICKHOUSE_USER=default
SQVIZ_CLICKHOUSE_PASSWORD=
SQVIZ_SECRET_CLICKHOUSE_DEFAULT=
SQVIZ_CLICKHOUSE_DATABASE=default
SQVIZ_POSTGREST_URL=http://localhost:3000
SQVIZ_POSTGREST_FORWARD_BEARER=false
SQVIZ_ALERTS_ENABLED=false
SQVIZ_ALERT_RULES_JSON=[]
SQVIZ_ALERT_LOAD_PERSISTED=true
SQVIZ_ALERT_WORKER_KEY=dev-alert-worker-key
SQVIZ_ALERT_POLL_SECONDS=30
SQVIZ_ALERT_DEDUPE_SECONDS=300

# Configure these to enable browser OIDC sign-in buttons.
SQVIZ_OIDC_GOOGLE_CLIENT_ID=
SQVIZ_OIDC_MICROSOFT_CLIENT_ID=
SQVIZ_OIDC_KEYCLOAK_ISSUER=http://localhost:8089/realms/sqviz
SQVIZ_OIDC_KEYCLOAK_DISCOVERY_URL=http://keycloak:8080/realms/sqviz
SQVIZ_OIDC_KEYCLOAK_CLIENT_ID=uvoo-sqviz-web
SQVIZ_OIDC_KEYCLOAK_CLIENT_SECRET=
SQVIZ_OIDC_KEYCLOAK_TENANT_CLAIM=tenant_slug

# Example alert rule:
# SQVIZ_ALERTS_ENABLED=true
# SQVIZ_ALERT_RULES_JSON=[{"id":"log-volume","name":"High log volume","tenantId":"dev","enabled":true,"query":{"dataset":"logs","groupBy":"service_name","aggregation":"count"},"condition":{"operator":"gt","threshold":100},"intervalSeconds":60,"contacts":[{"kind":"webhook","target":"http://example-webhook:8080/alerts","config":{}}]}]
