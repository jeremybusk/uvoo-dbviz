DBVIZ_ADDR=:8080
DBVIZ_AUTH_DEV_MODE=true
DBVIZ_CLICKHOUSE_URL=http://clickhouse:8123
DBVIZ_CLICKHOUSE_USER=default
DBVIZ_CLICKHOUSE_PASSWORD=
DBVIZ_SECRET_CLICKHOUSE_DEFAULT=
DBVIZ_CLICKHOUSE_DATABASE=default
DBVIZ_POSTGREST_URL=http://localhost:3000
DBVIZ_ALERTS_ENABLED=false
DBVIZ_ALERT_RULES_JSON=[]
DBVIZ_ALERT_LOAD_PERSISTED=true
DBVIZ_ALERT_WORKER_KEY=dev-alert-worker-key
DBVIZ_ALERT_POLL_SECONDS=30
DBVIZ_ALERT_DEDUPE_SECONDS=300

# Configure these to enable browser OIDC sign-in buttons.
DBVIZ_OIDC_GOOGLE_CLIENT_ID=
DBVIZ_OIDC_MICROSOFT_CLIENT_ID=
DBVIZ_OIDC_KEYCLOAK_ISSUER=http://localhost:8089/realms/dbviz
DBVIZ_OIDC_KEYCLOAK_CLIENT_ID=uvoo-dbviz-web
DBVIZ_OIDC_KEYCLOAK_CLIENT_SECRET=
DBVIZ_OIDC_KEYCLOAK_TENANT_CLAIM=tenant_slug

# Example alert rule:
# DBVIZ_ALERTS_ENABLED=true
# DBVIZ_ALERT_RULES_JSON=[{"id":"log-volume","name":"High log volume","tenantId":"dev","enabled":true,"query":{"dataset":"logs","groupBy":"service_name","aggregation":"count"},"condition":{"operator":"gt","threshold":100},"intervalSeconds":60,"contacts":[{"kind":"webhook","target":"http://example-webhook:8080/alerts","config":{}}]}]
